# =============================================================================
# Decepticon — Environment Variables
# =============================================================================
# The installer copies this file to ~/.botron/.env
# Edit with: decepticon config

# --- LLM API Keys (required: at least one) ---
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
# GOOGLE_API_KEY=your-google-key-here
# MINIMAX_API_KEY=your-minimax-key-here

# OLLAMA_MODEL=llama3.2
# OLLAMA_API_BASE=http://localhost:11434

# --- LiteLLM Proxy ---
LITELLM_MASTER_KEY=sk-decepticon-master
LITELLM_SALT_KEY=sk-decepticon-salt-change-me

# --- PostgreSQL ---
POSTGRES_PASSWORD=decepticon

# --- Neo4j (Attack Chain Graph DB) ---
# Used when BOTRON_KG_BACKEND=neo4j
NEO4J_PASSWORD=decepticon-graph

# --- Model Profile ---
# eco  = Balanced (Opus/Sonnet/Haiku mix, recommended)
# max  = Maximum performance (Opus everywhere, expensive)
# test = Cheapest (Haiku-only, for development)
# local = OpenRouter + Ollama (see docs for GPU requirements)
# nous  = DeepSeek V4 via Nous Portal (Hermes agent_key auth)
BOTRON_MODEL_PROFILE=eco

# --- Nous Portal (optional) ---
# Required when BOTRON_MODEL_PROFILE=nous
# Get key from: cat ~/.hermes/auth.json | jq -r '.agent_key'
# NOUS_API_KEY=sk-nous-your-key-here

# --- Model Provider ---
# api  = API keys via x-api-key header (default)
# auth = Claude Code OAuth subscription (Bearer token, no API cost)
BOTRON_MODEL_PROVIDER=api

# --- LangSmith Tracing (optional) ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-key-here
# LANGSMITH_PROJECT=decepticon

# --- Ports (optional) ---
# LANGGRAPH_PORT=2024
# LITELLM_PORT=4000
# POSTGRES_PORT=5432
# WEB_PORT=3000

# --- C2 Framework ---
# Default C2 server profile. Change to swap C2 frameworks.
# Options: c2-sliver (default), c2-havoc (future)
COMPOSE_PROFILES=c2-sliver

# --- Paths ---
# Install directory (used for workspace bind mount into containers).
# - Production: The installer sets this to ~/.botron automatically.
# - Development: `decepticon` (Python entry point) sets this to the repo root automatically.
# Do not use ~ (tilde) — Docker Compose cannot expand it.
# BOTRON_HOME=/home/youruser/.botron

# --- Advanced (optional) ---
# Disable automatic self-update checks on startup
# AUTO_UPDATE=false
# BOTRON_DEBUG=true
